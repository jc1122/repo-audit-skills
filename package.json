{
  "name": "repo-audit-skills",
  "version": "0.5.19",
  "description": "Deterministic, advisory repo-audit skills: a code-health family (complexity, duplication, dead-code, structure, quality) with the code-health-audit-pipeline umbrella, a test-audit family (test-quality-assurance, test-redundancy-triage) with the test-audit-pipeline umbrella, plus standalone hotspot, dependency, repo-hygiene, docs-consistency, security, and test-effectiveness leaves.",
  "license": "MIT",
  "bin": {
    "repo-audit-skills": "./bin/install-repo-audit-skills.js",
    "install-repo-audit-skills": "./bin/install-repo-audit-skills.js"
  },
  "scripts": {
    "check": "python3 scripts/run_checks.py",
    "check:vendored": "python3 scripts/check_vendored_common.py",
    "check:fixtures": "python3 scripts/check_skill_fixtures.py",
    "check:release": "python3 scripts/check_release.py",
    "check:selfaudit": "python3 scripts/check_self_audit.py",
    "check:security": "python3 scripts/check_security_audit.py",
    "check:hygiene": "python3 scripts/check_repo_hygiene.py",
    "check:docs": "python3 scripts/check_docs_consistency.py",
    "check:dependency": "python3 scripts/check_dependency_audit.py",
    "check:coverage": "python3 scripts/check_coverage_gap.py",
    "check:pytest": "python3 scripts/check_full_pytest.py",
    "pack:dry-run": "npm pack --dry-run"
  },
  "files": [
    "AGENTS.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "bin/",
    "scripts/",
    "shared/",
    "skills/",
    "!**/.git/**",
    "!**/__pycache__/**",
    "!**/*.pyc",
    "!**/*.pyo",
    "!**/.pytest_cache/**",
    "!**/.mypy_cache/**",
    "!**/.ruff_cache/**",
    "!**/.coverage",
    "!**/.coverage.*",
    "!**/self_audit_snapshot.json",
    "!**/coverage_gap_snapshot.json",
    "!**/security_snapshot.json",
    "!**/repo_hygiene_snapshot.json",
    "!**/docs_consistency_snapshot.json",
    "!**/dependency_snapshot.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jc1122/repo-audit-skills.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "jscpd": "^5.0.5"
  }
}
