{
  "name": "repo-audit-skills",
  "version": "0.1.0",
  "description": "Umbrella package for deterministic repository audit, test audit, redundancy triage, and performance benchmark skills.",
  "license": "MIT",
  "bin": {
    "repo-audit-skills": "./bin/install-repo-audit-skills.js",
    "install-repo-audit-skills": "./bin/install-repo-audit-skills.js"
  },
  "scripts": {
    "check": "npm run check:fixtures && npm run check:release",
    "check:fixtures": "python3 scripts/check_skill_fixtures.py",
    "check:release": "python3 scripts/check_release.py",
    "pack:dry-run": "npm pack --dry-run"
  },
  "files": [
    "AGENTS.md",
    "README.md",
    "LICENSE",
    "bin/",
    "scripts/",
    "skills/",
    "!**/.git/**",
    "!**/__pycache__/**",
    "!**/*.pyc",
    "!**/*.pyo",
    "!**/.pytest_cache/**",
    "!**/.mypy_cache/**"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jc1122/repo-audit-skills.git"
  },
  "engines": {
    "node": ">=18"
  }
}
